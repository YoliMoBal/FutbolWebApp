37709>>>>>>>>>>>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37712>>>>>>>>>>>>>        Case Begin
37712>>>>>>>>>>>>>            Case (NavigateData.eNavigateType = nfFromMain)
37714>>>>>>>>>>>>>                // If from main, this is a propbably a main file Select to Zoom.
37714>>>>>>>>>>>>>                Case Break
37715>>>>>>>>>>>>>
37715>>>>>>>>>>>>>            Case (NavigateData.eNavigateType = nfFromParent)
37718>>>>>>>>>>>>>                // If from parent, this is a constrained drill down.
37718>>>>>>>>>>>>>                Case Break
37719>>>>>>>>>>>>>
37719>>>>>>>>>>>>>            Case (NavigateData.eNavigateType = nfFromChild)
37722>>>>>>>>>>>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37722>>>>>>>>>>>>>                Case Break
37723>>>>>>>>>>>>>
37723>>>>>>>>>>>>>            Case Else // must be nfUndefined
37723>>>>>>>>>>>>>
37723>>>>>>>>>>>>>        Case End
37723>>>>>>>>>>>>>
37723>>>>>>>>>>>>>        Send SetActionButtons
37724>>>>>>>>>>>>>
37724>>>>>>>>>>>>>    End_Procedure
