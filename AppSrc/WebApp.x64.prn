38863>>>>>        WebSet pbRender of oSaveBtn to False
38864>>>>>        WebSet pbRender of oCancelChangesBtn to False
38865>>>>>        WebSet pbRender of oDeleteBtn to False
38866>>>>>
38866>>>>>        If (NavigateData.bReadOnly) Begin
38868>>>>>            WebSet pbRender of oEditBtn to True
38869>>>>>        End
38869>>>>>>
38869>>>>>        Else Begin
38870>>>>>            WebSet pbRender of oSaveBtn to True
38871>>>>>            WebSet pbRender of oCancelChangesBtn to True
38872>>>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38873>>>>>        End
38873>>>>>>
38873>>>>>    End_Procedure
