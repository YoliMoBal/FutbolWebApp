37713>>>>>>>>>>>>>        Case Begin
37713>>>>>>>>>>>>>            Case (NavigateData.eNavigateType = nfFromMain)
37715>>>>>>>>>>>>>                // If from main, this is a propbably a main file Select to Zoom.
37715>>>>>>>>>>>>>                Case Break
37716>>>>>>>>>>>>>
37716>>>>>>>>>>>>>            Case (NavigateData.eNavigateType = nfFromParent)
37719>>>>>>>>>>>>>                // If from parent, this is a constrained drill down.
37719>>>>>>>>>>>>>                Case Break
37720>>>>>>>>>>>>>
37720>>>>>>>>>>>>>            Case (NavigateData.eNavigateType = nfFromChild)
37723>>>>>>>>>>>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37723>>>>>>>>>>>>>                Case Break
37724>>>>>>>>>>>>>
37724>>>>>>>>>>>>>            Case Else // must be nfUndefined
37724>>>>>>>>>>>>>
37724>>>>>>>>>>>>>        Case End
37724>>>>>>>>>>>>>
37724>>>>>>>>>>>>>        Send SetActionButtons
37725>>>>>>>>>>>>>
37725>>>>>>>>>>>>>    End_Procedure
